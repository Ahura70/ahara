# VITE_GEMINI_API_KEY: Required for Gemini AI image analysis and recipe generation.
# Get your API key from: https://aistudio.google.com/app/apikey
# The VITE_ prefix is required for Vite build system to expose it to the frontend.
VITE_GEMINI_API_KEY="your_gemini_api_key_here"

# VITE_APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
VITE_APP_URL="http://localhost:5173"
